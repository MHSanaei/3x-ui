+		Password: hashed,
+		FullName: in.FullName,
+		Phone:    in.Phone,
+		Email:    email,
+		Role:     normalizeRole(in.Role),
+		Balance:  balance,
+	}
+	err = database.GetDB().Transaction(func(tx *gorm.DB) error {
