{
  "$schema": "vscode://schemas/launch",
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run dune (Debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "env": {
        "DUNE_DEBUG": "true",
        "DUNE_DB_FOLDER": "dune",
        "DUNE_LOG_FOLDER": "dune",
        "DUNE_BIN_FOLDER": "dune"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Run dune (Postgres)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "cwd": "${workspaceFolder}",
      "env": {
        "DUNE_DEBUG": "true",
        "DUNE_LOG_FOLDER": "dune",
        "DUNE_BIN_FOLDER": "dune",
        "DUNE_DB_TYPE": "postgres",
        "DUNE_DB_DSN": "postgres://xui:xuipass@127.0.0.1:5432/xui?sslmode=disable",
        "PATH": "C:\\Program Files\\PostgreSQL\\18\\bin;${env:PATH}"
      },
      "console": "integratedTerminal"
    },
  ]
}