[Unit]
Description=dune Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/default/dune
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/dune/
ExecStart=/usr/local/dune/dune
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
