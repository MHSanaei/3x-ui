# 3x-ui environment configuration.
# Copy to ".env" and adjust. All variables are optional and fall back to the
# defaults shown here when unset.

# --- General ---
# Enable verbose debug logging and the Gin debug mode.
XUI_DEBUG=true
# Log verbosity when XUI_DEBUG is false: debug | info | notice | warning | error
XUI_LOG_LEVEL=info
# Skip sending the HSTS header even when serving direct HTTPS.
XUI_SKIP_HSTS=false

# --- Paths ---
# Where x-ui.db (SQLite), logs and the xray binary/geo files live.
XUI_DB_FOLDER=x-ui
XUI_LOG_FOLDER=x-ui
XUI_BIN_FOLDER=x-ui

# --- Database ---
# Backend: "sqlite" (default) or "postgres".
# XUI_DB_TYPE=sqlite
# PostgreSQL DSN, required only when XUI_DB_TYPE=postgres. The target database
# must already exist; tables are auto-migrated on start.
# XUI_DB_DSN=postgres://postgres:root@127.0.0.1:5432/xui?sslmode=disable
# Connection pool sizing (defaults: sqlite 8/4, postgres 25/25).
# XUI_DB_MAX_OPEN_CONNS=25
# XUI_DB_MAX_IDLE_CONNS=25
