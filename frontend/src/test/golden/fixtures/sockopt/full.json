{
  "acceptProxyProtocol": true,
  "tcpFastOpen": true,
  "mark": 100,
  "tproxy": "redirect",
  "tcpMptcp": true,
  "penetrate": false,
  "domainStrategy": "UseIP",
  "tcpMaxSeg": 1440,
  "dialerProxy": "out-proxy-tag",
  "tcpKeepAliveInterval": 15,
  "tcpKeepAliveIdle": 300,
  "tcpUserTimeout": 10000,
  "tcpcongestion": "cubic",
  "V6Only": false,
  "tcpWindowClamp": 600,
  "interfaceName": "eth0",
  "trustedXForwardedFor": ["10.0.0.0/8", "192.168.0.0/16"]
}
